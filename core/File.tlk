// no-core

use { Array } from ./Array.tlk
use { open_path, _io_read, _io_write, _io_close, O_RDONLY, O_WRONLY, O_RDWR, O_CREAT, O_TRUNC, O_APPEND, S_IRUSR, S_IWUSR, EAGAIN, POLLIN, POLLOUT } from ./IO.tlk
use { _alloc } from ./Memory.tlk
use { Add, Comparable } from ./Operators.tlk
use { String } from ./String.tlk

public struct Path {
	let components: Array<String>
}

public enum FileMode {
	case read
	case write
	case append
}

public struct Rawfile {
	let fd: Int

	public func open_read(path: String) -> Rawfile {
		let fd = open_path(path, O_RDONLY, 0)
		Rawfile(fd: fd)
	}

	public func open_write(path: String) -> Rawfile {
		let mode = S_IRUSR + S_IWUSR
		let fd = open_path(path, O_WRONLY + O_CREAT + O_TRUNC, mode)
		Rawfile(fd: fd)
	}

	public func open_append(path: String) -> Rawfile {
		let mode = S_IRUSR + S_IWUSR
		let fd = open_path(path, O_WRONLY + O_CREAT + O_APPEND, mode)
		Rawfile(fd: fd)
	}

	public func read(buf: RawPtr, count: Int) -> Int {
		_io_read(self.fd, buf, count)
	}

	public func write(buf: RawPtr, count: Int) -> Int {
		_io_write(self.fd, buf, count)
	}

	public func close() -> Int {
		_io_close(self.fd)
	}

	public func is_valid() -> Bool { self.fd >= 0 }
}
