test "can be created for int" {
	let range = Range(lower: 1, upper: 5)
	assert(range.lower == 1)
	assert(range.upper == 5)
}

test "can be created for float" {
	let range = Range(lower: 1.0, upper: 5.0)
	assert(range.lower == 1.0)
	assert(range.upper == 5.0)
}

test "can check contains for int" {
	let range = Range(lower: 1, upper: 5)
	assert(range.contains(1))
	assert(range.contains(2))
	assert(!range.contains(5))
	assert(!range.contains(6))
}

test "range literal is half-open" {
	let range = 1..<5
	assert(range.contains(1))
	assert(range.contains(4))
	assert(!range.contains(5))
}

test "closed range literal is inclusive" {
	let range = 1..5
	assert(range.contains(1))
	assert(range.contains(5))
	assert(!range.contains(6))
}

test "can check contains for float" {
	let range = 1.0..<5.0
	assert(range.contains(1.0))
	assert(range.contains(2.0))
	assert(!range.contains(5.0))
	assert(!range.contains(6.0))
}

test "can iterate over int range" {
	let i = 0
	for _ in 0..4 {
		i = i + 1
	}
	assert(i == 5)
}

test "int.times" {
	let results = 5.times { x in x * 2 }
	assert(results.count == 5)
	assert(results[4] == 8)
}

test "int.times closures mutate captured values" {
	let i = 0
	5.times { x in i = i + 1 }
	assert(i == 5)
}

test "closed range ending at Int max terminates" {
	let max = 9223372036854775807
	let i = 0
	for _ in (max - 2)..max {
		i = i + 1
	}
	assert(i == 3)
}
