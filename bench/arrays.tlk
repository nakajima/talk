// Archetype: collections — Array growth, bounds-checked get (inlined
// through the small-function pass), iteration.
func bench(n: Int) -> Int {
	let xs: Array<Int> = []
	let i = 0
	loop i < n {
		xs.push(i)
		i = i + 1
	}
	let total = 0
	let j = 0
	loop j < xs.count {
		total = total + xs.get(j)
		j = j + 1
	}
	total
}
print(bench(120000))
