use ansi::{ ColorfulString }
use testing::{ Failure, TestCase, fail, registerTest, report }

public let __talktalk_tests = Array<TestCase>(capacity: 0)
public let __talktalk_failures = Array<Failure>(capacity: 0)
let __talktalk_current_test = ""
let __talktalk_filter_enabled = false
let __talktalk_filter_name = ""

@handle 'registerTest { testCase in
	if __talktalk_filter_enabled {
		if testCase.name == __talktalk_filter_name {
			__talktalk_tests.push(TestCase(name: testCase.name.to_string(), block: testCase.block))
		}
	} else {
		__talktalk_tests.push(TestCase(name: testCase.name.to_string(), block: testCase.block))
	}
	'continue ()
}

@handle 'fail { message in
	print_raw(ColorfulString.red("F"))

	__talktalk_failures.push(
		Failure(test_name: __talktalk_current_test.to_string(), assertion: message)
	)
	'continue ()
}

public func __talktalk_runAllAndReport() -> Int {
	for testCase in __talktalk_tests {
		__talktalk_current_test = testCase.name.to_string()
		testCase.block()
		print_raw(ColorfulString.green("."))
	}

	print("")
	report(__talktalk_tests, __talktalk_failures)
	__talktalk_failures.count
}
