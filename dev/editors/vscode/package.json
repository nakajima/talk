{
  "name": "talktalk",
  "displayName": "talktalk",
  "publisher": "talktalk",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:talktalk",
    "workspaceContains:**/*.tlk",
    "onCommand:talktalk.restartLsp",
    "onCommand:talktalk.setCorePath",
    "onCommand:talktalk.clearCorePath",
    "onCommand:talktalk.setStdlibPath",
    "onCommand:talktalk.clearStdlibPath"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "talktalk.restartLsp",
        "title": "TalkTalk: Restart Language Server"
      },
      {
        "command": "talktalk.setCorePath",
        "title": "TalkTalk: Set Core Path"
      },
      {
        "command": "talktalk.clearCorePath",
        "title": "TalkTalk: Clear Core Path"
      },
      {
        "command": "talktalk.setStdlibPath",
        "title": "TalkTalk: Set Stdlib Path"
      },
      {
        "command": "talktalk.clearStdlibPath",
        "title": "TalkTalk: Clear Stdlib Path"
      }
    ],
    "configuration": {
      "title": "TalkTalk",
      "properties": {
        "talktalk.corePath": {
          "type": "string",
          "default": "",
          "description": "Directory containing core .tlk files to pass as TALK_CORE_PATH to the language server. Supports a leading ~/. If empty, the extension forwards TALK_CORE_PATH from its own environment when present."
        },
        "talktalk.stdlibPath": {
          "type": "string",
          "default": "",
          "description": "Directory containing stdlib .tlk files to pass as TALK_STDLIB_PATH to the language server. Supports a leading ~/. If empty, the extension forwards TALK_STDLIB_PATH from its own environment when present."
        }
      }
    },
    "languages": [
      {
        "id": "talktalk",
        "aliases": [
          "TalkTalk",
          "talktalk"
        ],
        "extensions": [
          ".tlk"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "talktalk",
        "scopeName": "source.talktalk",
        "path": "./syntax/talktalk.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.101.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.25.5",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
