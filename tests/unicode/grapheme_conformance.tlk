let failures = 0
let total = 0

func check(s: String, expected: String, case_number: Int) -> () {
	total = total + 1
	let lens = ""
	for ch in s {
		lens = lens + ch.utf8_count().show() + ","
	}
	// Compare through borrows: String == consumes its operands,
	// which the failure report below still needs.
	if lens.as_substring().equals_string(expected) {
		return ()
	}
	failures = failures + 1
	print("case " + case_number.show() + ": got " + lens + " want " + expected)
}

