print("hello" == "hello")
print("hello" == "world")
print("hello".utf8().slice(1, 3).to_string())
print("hello".as_substring().utf8().slice(1, 3).to_string())
match "hello world".find("world") {
	.some(i) -> print(i),
	.none -> print(0 - 1)
}
match "hello world".find("missing") {
	.some(i) -> print(i),
	.none -> print(0 - 1)
}
match "banana".find_from("na", 3) {
	.some(i) -> print(i),
	.none -> print(0 - 1)
}
