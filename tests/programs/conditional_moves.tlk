func take(s: String) -> Int {
	s.byte_count
}

func search(flag: Bool) -> Int {
	let total = 0
	let i = 0
	loop i < 4 {
		i = i + 1
		let local = "x" + "y"
		if (flag) {
			total = total + take(local)
			continue
		}
		total = total + local.byte_count
	}
	total
}

print(search(true))
print(search(false))
